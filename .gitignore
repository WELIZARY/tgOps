# ============================================================
# tgOPS - .gitignore
# Go + DevOps инструменты, macOS / Windows
# ============================================================

# - Бинарники / сборка -
/tgops
/tgops.exe
/bin/
/dist/
*.out

# - Go тулчейн -
vendor/
*.test
*.prof
coverage.out
coverage.html

# - Секреты и конфиг (НИКОГДА не коммитить реальные данные) -
bot_token.txt
configs/config.yaml
configs/config.local.yaml
*.pem
*.key
*.crt
*.p12
*.pfx
.env
.env.*
!.env.example

# - SSH ключи -
id_rsa*
id_ed25519*
*.pub
known_hosts

# - Приватные ключи для подключения к серверам мониторинга -
# Все ключи хранятся в keys/, не коммитятся
# Для добавления ключей смотри configs/config.ssh.servers.example.yaml
keys/
!keys/.gitkeep

# - Документация проекта (только для разработчика) -
tgops.md

# - Terraform состояние и креды -
deployments/terraform/.terraform/
deployments/terraform/*.tfstate
deployments/terraform/*.tfstate.backup
deployments/terraform/*.tfvars
deployments/terraform/.terraform.lock.hcl
crash.log

# - Docker локальные переопределения -
docker-compose.override.yml
docker-compose.local.yml

# - IDE: JetBrains (GoLand) -
.idea/
*.iml
*.iws
*.ipr

# - IDE: VS Code -
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# - macOS -
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# - Windows -
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# - Логи -
*.log
logs/
# исключение: модуль просмотра логов — не является файлами логов
!internal/modules/logs/
/tmp/

# - Временные файлы и тестовые фикстуры -
testdata/tmp/
*.tmp
